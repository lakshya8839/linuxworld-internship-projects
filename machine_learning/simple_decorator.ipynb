    "\n",
    "def decorator_function(func):\n",
    "    def wrapper():\n",
    "        print(\"Start\")\n",
    "        func()\n",
    "    return wrapper\n",
    "\n",
    "@decorator_function\n",
    "def greet():\n",
    "    print(\"Hello!\")\n",
    "\n",
    "greet()"
